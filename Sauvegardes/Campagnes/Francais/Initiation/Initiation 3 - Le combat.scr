		Persos(9).NumeroEquipe = 2
		Persos(10).NumeroEquipe = 2
		Persos(11).NumeroEquipe = 2
		Persos(12).NumeroEquipe = 2
		Persos(13).NumeroEquipe = 2
		Persos(14).NumeroEquipe = 2

		Persos(5).Attaquer_Perso 0
		Persos(6).Attaquer_Perso 0
		Persos(7).Attaquer_Perso 0
		Persos(8).Attaquer_Perso 0
		Persos(9).Attaquer_Perso 0
