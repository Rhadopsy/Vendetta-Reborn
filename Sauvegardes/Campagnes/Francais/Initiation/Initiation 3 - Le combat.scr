		Jeu.Activer_Effet_Perso 17, Persos(14)
		Interface.Objectifs_Ajouter "- Vaincre 10 mannequins."
	End If
End Sub

Sub DESACTIVER_AUTOMATES()
	If Not Persos(5).Vivant Then
		Persos(5).IA = False
	End If
	If Not Persos(6).Vivant Then
		Persos(6).IA = False
	End If
	If Not Persos(6).Vivant Then
		Persos(7).IA = False
	End If
	If Not Persos(6).Vivant Then
		Persos(8).IA = False
	End If
	If Not Persos(6).Vivant Then
		Persos(9).IA = False
	End If
	If Not Persos(6).Vivant Then
		Persos(10).IA = False
	End If
	If Not Persos(6).Vivant Then
		Persos(11).IA = False
	End If
	If Not Persos(6).Vivant Then
		Persos(12).IA = False
	End If
	If Not Persos(6).Vivant Then
		Persos(13).IA = False
	End If
	If Not Persos(6).Vivant Then
		Persos(14).IA = False
	End If
End Sub

Sub EFFETS_SUR_INVENTAIRE()
	Dim i
	for i=0 to 31
		If Persos(1).Objet_Inventaire_Actif(i) Then
			Interface.Activer_Effet_Visuel 35, Interface.Definir_InventaireBoutonsObjetsPositionX(i) + 16, Interface.Definir_InventaireBoutonsObjetsPositionY(i) + 16
		End If
	Next
End Sub

Sub EFFETS_SUR_INVENTAIRE_CATEGORIE(Byval Categorie)
	Dim i
	for i=0 to 31
		If Persos(1).Objet_Inventaire_Actif(i) Then
			If Parametres.Objet_Categorie(Persos(1).Objet_Inventaire_Type(i)) = Categorie Then
				Interface.Activer_Effet_Visuel 35, Interface.Definir_InventaireBoutonsObjetsPositionX(i) + 16, Interface.Definir_InventaireBoutonsObjetsPositionY(i) + 16
			End If
		End If
	Next	
End Sub